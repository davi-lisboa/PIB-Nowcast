import pandas as pd
from statsmodels.tsa.x13 import x13_arima_analysis as x13


# %%
def seas_adj(base_df, specs_df, x13_path):

    non_sa_vars = specs_df.query("seas_adj == 0")['variable'].to_list()

    base_df_sa = base_df.copy(deep=True)

    for col in non_sa_vars:
        col_sa = x13(base_df_sa[[col]].dropna(), ).seasadj
        # Para preservar índice
        col_sa = base_df_sa.drop(columns=col).merge(col_sa, left_index=True, right_index=True, how='outer')[[col]]

        base_df_sa[col] = col_sa

    return base_df_sa

